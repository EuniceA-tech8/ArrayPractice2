// Write Swift logic to remove the largest value from an array of integers

let numbers = [3, 5, 3, 100, 5]

func removeLargest(from arr: [Int]) -> [Int] {
    guard let maxVal = arr.max() else { return arr }
    return arr.filter { $0 != maxVal }
}

let result = removeLargest(from: numbers)
print(result)
