// Write Swift logic to find the larger value of a given array of integers and set all the other elements with that value. print the changed array

func largestValue(arr: [Int]) -> [Int] {

    var array = arr  

    var largestVal = arr[0]

    for num in arr {

        if num > largestVal {

            largestVal = num

        }

    }

    

    for index in 0..<arr.count {

        if array[index] != largestVal {

            array[index] = largestVal

        }

    }

    return array

}

largestValue(arr: nums)



